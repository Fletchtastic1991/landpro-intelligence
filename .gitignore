# ─── Python virtual environment — never commit this ─────────────────────────
venv/
.venv/
env/
ENV/

# ─── Python cache files ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.production

# ─── Distribution / build ────────────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/

# ─── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── Editor / OS ─────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ─── Jupyter notebooks (if used for data exploration) ────────────────────────
.ipynb_checkpoints/

# ─── GeoTIFF and large data files (use cloud storage for these) ──────────────
*.tif
*.tiff
*.geotiff
data/raw/